PORT=3000
JWT_SECRET=change-me
# Required for POST /api/tickets/:id/classify-ticket-type (OpenAI Responses API via fetch)
OPENAI_API_KEY=
# Optional; defaults to gpt-5.4-nano
OPENAI_MODEL=
# Optional; used for public ticket image validation (Responses API); defaults to gpt-5.4-mini
OPENAI_ATTACHMENT_VALIDATION_MODEL=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=postgres
DB_PASSWORD=postgres

# ------- Test database (used by `make test`) -------
# The test suite uses .env.test automatically (via DOTENV_CONFIG_PATH).
# Test DB runs on port 5433 with database app_test.
# DB_PORT=5433
# DB_NAME=app_test
