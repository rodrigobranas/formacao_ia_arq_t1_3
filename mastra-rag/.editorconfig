# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
tab_width = 2

# Align with oxfmt printWidth
[*.{js,ts,jsx,tsx,json,css,scss,md}]
max_line_length = 100

# JSON files use 4 spaces
[*.{json,jsonc}]
indent_size = 4
tab_width = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false

# Makefiles
[Makefile]
indent_style = tab

# Go/Proto/Make files use tabs
[*.{go,proto,make}]
indent_style = tab
