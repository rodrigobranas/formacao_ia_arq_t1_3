{
    "name": "backend",
    "type": "module",
    "scripts": {
        "cli": "bun src/cli.ts",
        "dev": "bun --watch src/cli.ts papers",
        "build": "bun build src/cli.ts --outdir dist --target bun",
        "start": "bun dist/cli.js",
        "papers": "bun src/cli.ts papers",
        "ingest": "bun src/cli.ts ingest",
        "ask": "bun src/cli.ts ask",
        "test": "bunx vitest run --config vitest.config.ts",
        "test:watch": "bunx vitest --config vitest.config.ts",
        "typecheck": "bunx tsgo --noEmit"
    },
    "dependencies": {
        "@mastra/core": "^1.24.1",
        "@mastra/libsql": "^1.8.0",
        "@mastra/rag": "^2.2.0",
        "ai": "^6.0.159",
        "citty": "^0.2.2",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bun": "^1.3.10",
        "@types/node": "^25.5.0",
        "vitest": "4.1.0"
    }
}
